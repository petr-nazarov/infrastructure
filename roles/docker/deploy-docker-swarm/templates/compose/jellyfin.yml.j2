# services:
  jellyfin:
    image: jellyfin/jellyfin:latest
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
    # ports:
    #   - "8096:8096"
    volumes:
      - "{{ remote_data }}/jellyfin:/config"
      - "/mnt/storage/Media:/data/Media"
    environment:
      - UID={{ puid }}
      - GID={{ pgid }}
      - JELLYFIN_Password={{ admin_pass }}
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
