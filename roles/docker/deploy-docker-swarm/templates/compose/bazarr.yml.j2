# services:
  bazarr:
    image: lscr.io/linuxserver/bazarr:latest
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    volumes:
      - "{{ remote_data }}/bazarr:/config"
      - "/mnt/storage/Media:/Media"
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
