# services:
  transmission:
    image: lscr.io/linuxserver/transmission:latest
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    volumes:
      - "{{ remote_data }}/transmission:/config"
      - "/mnt/storage/Media:/Media"
    ports:
      - target: 51413 
        published: 6881
        mode: host # Optional: bypasses mesh for direct performance if on manager
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
