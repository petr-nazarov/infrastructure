# Define the snippet
(my_tls) {
    tls /etc/letsencrypt/live/{{ public_top_domain }}/fullchain.pem /etc/letsencrypt/live/{{ public_top_domain }}/privkey.pem
}

# Global Options (Optional)
{
    email {{ personal_email }}
    auto_https disable_redirects
}

# Public domains
rss.{{ public_top_domain }} {
    import my_tls
    reverse_proxy miniflux:8080
}

dns.{{ public_top_domain }} {
    import my_tls
    reverse_proxy adguardhome:80
}
wg-home.{{ public_top_domain }} {
    import my_tls
    reverse_proxy wg-easy:51821
}
ntf.{{ public_top_domain }} {
    import my_tls
    reverse_proxy gotify:80
}
## Internal domains
portainer.{{ top_local_domain }}:80 {
    reverse_proxy portainer:9000
}
home.{{ top_local_domain }}:80 {
    reverse_proxy glance:8080
}
status.{{ top_local_domain }}:80 {
    reverse_proxy gatus:8080
}
beszel.{{ top_local_domain }}:80 {
    reverse_proxy beszel:8090
}


## Edge
sync.{{ local_edge_domain }}:80 {
    reverse_proxy syncthing-edge:8384
}


## Media
jellyfin.{{ local_media_domain }}:80 {
    reverse_proxy jellyfin:8096
}
sonarr.{{ local_media_domain }}:80 {
    reverse_proxy sonarr:8989
}
radarr.{{ local_media_domain }}:80 {
    reverse_proxy radarr:7878
}
bazarr.{{ local_media_domain }}:80 {
    reverse_proxy bazarr:6767
}
prowlarr.{{ local_media_domain }}:80 {
    reverse_proxy prowlarr:9696
}
transmission.{{ local_media_domain }}:80 {
    reverse_proxy transmission:9091
}
sync.{{ local_media_domain }}:80 {
    reverse_proxy syncthing-media:8384
}
# Desktop
sync.{{ local_desktop_domain }}:80 {
    reverse_proxy {{desktop_ip }}:8384
}
sunshine.{{ local_desktop_domain }}:80 {
    reverse_proxy {{desktop_ip }}:47990
}

