# services:
  caddy:
    image: caddy:2.10.2-alpine
    ports:
      - target: 80
        published: 80
        mode: host
      - target: 443
        published: 443
        mode: host
    volumes:
      - {{ remote_config }}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - {{ remote_data }}/caddy_data:/data
      - {{ remote_data }}/caddy_config:/config
      - {{ remote_data }}/letsencrypt:/etc/letsencrypt:ro
    networks:
      - local_net
    deploy:
      placement:
        constraints:
          - node.role == manager

