# services:
  sonarr:
    image: linuxserver/sonarr:latest
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    volumes:
      - "{{ remote_data }}/sonarr:/config"
      - "/mnt/storage/Media:/Media"
