# services:
  qbittorrent:
    image: qbittorrentofficial/qbittorrent-nox:latest
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      - WEBUI_PORT=8080
      - TORRENTING_PORT=6881
      - QBT_LEGAL_NOTICE=confirm
      - QBT_VERSION=latest
      - QBT_TORRENTING_PORT=${QBT_TORRENTING_PORT}
      - QBT_WEBUI_PORT=${QBT_WEBUI_PORT}
    volumes:
      - "{{ remote_data }}/qbittorrent:/config"
      - "/mnt/storage/Media:/Media"
    ports:
      - target: 6881 
        published: 6881
        mode: host # Optional: bypasses mesh for direct performance if on manager
    deploy:
      replicas: 0
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
      labels:
        - "traefik.enable=true"
        - "traefik.http.routers.qbittorrent.rule=Host(`torrent.{{ local_media_domain }}`)"
        - "traefik.http.services.qbittorrent.loadbalancer.server.port=8080"
        - "traefik.http.routers.qbittorrent.entrypoints=web"
