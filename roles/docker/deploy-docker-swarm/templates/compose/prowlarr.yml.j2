# services:
  prowlarr:
    image: linuxserver/prowlarr
    networks:
      - local_net
    dns:
      - "{{ local_dns }}"
    volumes:
      - "{{ remote_data }}/prowlarr:/config"
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.hostname == {{ hostname_media }}"
