# services:
  adguardhome:
    image: adguard/adguardhome:latest
    networks:
      - local_net
    environment:
      TZ: "{{ tz }}"
    volumes:
      - "{{ remote_data }}/adguard/work:/opt/adguardhome/work"
      - "{{ remote_data }}/adguard/conf:/opt/adguardhome/conf"
      - "{{ remote_data }}/letsencrypt:/opt/adguardhome/certs:ro"
    ports:
      # DNS Ports - mode: host is critical for seeing client IPs
      - target: 53
        published: 53
        protocol: tcp
        mode: host
      - target: 53
        published: 53
        protocol: udp
        mode: host
      # Admin UI Port
      # - target: 80
      #   published: 8081
      #   protocol: tcp
      #   mode: ingress
      # Optional: Encrypted DNS
      - target: 853
        published: 853
        protocol: tcp
        mode: host
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints:
          - "node.role == manager"
