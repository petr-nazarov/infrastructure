# services:
  gotify:
    image: gotify/server:latest
    networks:
      - local_net
    # dns:
    #   - "{{ local_dns }}"
    environment:
      GOTIFY_DEFAULTUSER_PASS: "{{ admin_pass }}"
      TZ: "{{ tz }}"
    volumes:
      - "{{ remote_data }}/gotify:/app/data"
    deploy:
      replicas: 1
      placement:
        constraints:
          - "node.role == manager"
